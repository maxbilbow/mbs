								{
									"test": "has_biome_tag",
									"operator": "==",
									"value": "roofed"
								},
								{
									"test": "has_biome_tag",
									"operator": "==",
									"value": "forest"
								},
								{
									"test": "has_biome_tag",
									"operator": "==",
									"value": "plains"
								},
								{
									"test": "has_biome_tag",
									"operator": "==",
									"value": "taiga"
								},
								{
									"test": "has_biome_tag",
									"operator": "==",
									"value": "meadow"
								},
								{
									"test": "has_biome_tag",
									"operator": "==",
									"value": "cherry_grove"
