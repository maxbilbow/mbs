{
    "format_version": "1.13.0",
    "minecraft:feature_rules": {
        "description": {
            "identifier": "wypnt_mss:jungle_pyramid_feature_rule",
            "places_feature": "wypnt_mss:jungle_pyramid_1_mcstructure"
        },
        "conditions": {
            "placement_pass": "surface_pass",
			"minecraft:biome_filter": [
				{
					"all_of": [
						{
							"test": "has_biome_tag",
							"operator": "==",
							"value": "jungle"
						}
					]
				},
				{
					"none_of": [
						{
							"test": "has_biome_tag",
							"operator": "==",
							"value": "bamboo"
						},
						{
							"test": "has_biome_tag",
							"operator": "==",
							"value": "edge"
						}
					]
				}
			]
        },
		"distribution": {
			"iterations": 1,
			"scatter_chance": {
				"numerator": 1,
				"denominator": 175
			},
			"x": {
				"distribution": "uniform",
				"extent": [
					-8,
					8
				]
			},
			"y": "query.heightmap(variable.worldx, variable.worldz) + -3",
			"z": {
				"distribution": "uniform",
				"extent": [
					-8,
					8
				]
			}
		}
    }
}