{
    "format_version": "1.13.0",
    "minecraft:feature_rules": {
        "description": {
            "identifier": "wypnt_mss:desert_pyramid_feature_rule",
            "places_feature": "wypnt_mss:desert_pyramid_1_mcstructure"
        },
        "conditions": {
            "placement_pass": "surface_pass",
            "minecraft:biome_filter": [
                {
                    "all_of": [
                        {
                            "test": "has_biome_tag",
                            "operator": "!=",
                            "value": "ocean"
                        },
                        {
                            "test": "has_biome_tag",
                            "operator": "!=",
                            "value": "river"
                        },
                        {
                            "any_of": [
                                {
                                    "test": "has_biome_tag",
                                    "operator": "==",
                                    "value": "desert"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        "distribution": {
            "iterations": 1,
			"scatter_chance": {
				"numerator": 1,
				"denominator": 330
			},
            "x": 0,
            "y": "query.heightmap(variable.worldx, variable.worldz) + 0",
            "z": 0
        }
    }
}