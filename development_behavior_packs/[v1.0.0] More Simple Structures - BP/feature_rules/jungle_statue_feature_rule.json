{
	"format_version": "1.13.0",
	"minecraft:feature_rules": {
		"description": {
			"identifier": "wypnt_mss:jungle_statue_feature_rule",
			"places_feature": "wypnt_mss:select_jungle_statue_feature"
		},
		"conditions": {
			"placement_pass": "surface_pass",
			"minecraft:biome_filter": [
				{
					"all_of": [
						{
							"test": "has_biome_tag",
							"operator": "!=",
							"value": "ocean"
						},
						{
							"test": "has_biome_tag",
							"operator": "!=",
							"value": "river"
						},
						{
							"any_of": [
								{
									"test": "has_biome_tag",
									"operator": "==",
									"value": "jungle"
								}
							]
						}
					]
				},
				{
					"none_of": [
						{
							"test": "has_biome_tag",
							"operator": "==",
							"value": "edge"
						},
						{
							"test": "has_biome_tag",
							"operator": "==",
							"value": "bamboo"
						}
					]
				}
			]
		},
		"distribution": {
			"iterations": 1,
			"scatter_chance": {
				"numerator": 1,
				"denominator": 100
			},
            "x": {
                "distribution": "uniform",
                "extent": [
                    0,
                    16
                ]
            },
			"y": "query.heightmap(variable.worldx, variable.worldz) + 0",
            "z": {
                "distribution": "uniform",
                "extent": [
                    0,
                    16
                ]
            }
		}
	}
}