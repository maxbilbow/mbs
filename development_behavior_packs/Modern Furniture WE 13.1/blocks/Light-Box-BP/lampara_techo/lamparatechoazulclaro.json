{
	"format_version": "1.20.20",
	"minecraft:block": {
		"description": {
			"identifier": "f:lamparatechoazulclaro",
			"states": {
				"custom:geometry": [
					"encendido",
					"apagado"		
				]
			},
			"menu_category": {
				"category": "items"
			}
		},
		"components": {
			"minecraft:custom_components": [
				"content_mf:on_click_light"
			],
			"minecraft:material_instances": {
				"*": {
					"render_method": "opaque",
					"texture": "lamparaazulclaro"
				}
			},
			"minecraft:geometry": "geometry.lamparatecho",
			"minecraft:collision_box": {
				"origin": [
					-6,
					0,
					-6
				],
				"size": [
					12,
					16,
					12
				]
			},
			"minecraft:selection_box": {
				"origin": [
					-6,
					0,
					-6
				],
				"size": [
					12,
					16,
					12
				]
			},
			"minecraft:destructible_by_mining": {
				"seconds_to_destroy": 0.4
			},
			"minecraft:destructible_by_explosion": {
				"explosion_resistance": 15
			},
			"minecraft:flammable": {
				"destroy_chance_modifier": 20,
				"catch_chance_modifier": 5
			}
		},
		"permutations": [
			{
				"condition": "q.block_state('custom:geometry') == 'encendido'",
				"components": {
					"minecraft:light_emission": 15,
					"minecraft:geometry": "geometry.lamparatecho"
				}
			},
			{
				"condition": "q.block_state('custom:geometry') == 'apagado'",
				"components": {
					"minecraft:geometry": "geometry.lamparatecho_apagado",
					"minecraft:light_emission": 0
				}
			}
		],
		"events": {}
	}
}