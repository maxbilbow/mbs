{
	"format_version": "1.20.30",
	"animation_controllers": {
		"controller.animation.oberon.not_walk": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"not_walk_sequence": "query.modified_move_speed<=0.4&&query.life_time-variable.state_time>20&&query.property('cso:state')!='dying'"
						}
					],
					"on_entry": [
						"variable.state_time=query.life_time;"
					]
				},
				"not_walk_sequence": {
					"transitions": [
						{
							"not_walk_sequence.end": "1"
						}
					],
					"on_entry": [
						"variable.state_time=query.life_time;",
						"/summon cso:oberon_fix_afk"
					]
				},
				"not_walk_sequence.end": {
					"transitions": [
						{
							"default": "1"
						}
					],
					"on_entry": [
						"variable.state_time=query.life_time;"
					]
				}
			}
		}
	}
}