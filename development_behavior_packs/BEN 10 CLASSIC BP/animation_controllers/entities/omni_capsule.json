{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.falling_omni_capsule": {
			"states": {
				"default": {
					"transitions": [
						{
							"walking": "1"
						}
					]
				},
				"walking": {
					"transitions": [
						{
							"default": "query.state_time>=0.5"
						}
					],
					"on_entry": [
						"/effect @s slow_falling 1 1 true",
						"/particle minecraft:mobflame_single ~ ~2 ~",
						"/particle minecraft:mobflame_single ~ ~3 ~",
						"/playsound omni.falling_omni @a[r=50] ~ ~ ~ 1.0 1.0"
					]
				}
			}
		}
	}
}