{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.eyeice2": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"eyeice": "query.skin_id==0"
						}
					]
				},
				"eyeice": {
					"transitions": [
						{
							"default": "query.skin_id==0"
						}
					],
					"on_entry": [
						"/event entity @s eyeice2:spawmed"
					]
				}
			}
		},
		"controller.animation.eyeice2_attk": {
			"states": {
				"default": {
					"transitions": [
						{
							"use": "1"
						}
					],
					"on_entry": [
						"/effect @e[type=!power:eyeice2,family=!eyeguy,r=2,c=1] slowness 3 255 true"
					]
				},
				"use": {
					"transitions": [
						{
							"default": "1"
						}
					],
					"on_entry": [
						"/effect @e[type=!power:eyeice2,family=!eyeguy,r=2,c=1] slowness 3 255 true"
					]
				}
			}
		}
	}
}