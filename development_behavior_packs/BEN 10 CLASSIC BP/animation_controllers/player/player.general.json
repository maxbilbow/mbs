{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.player_normal": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"cleanup_phase_1": "query.variant==0"
						}
					]
				},
				"cleanup_phase_1": {
					"transitions": [
						{
							"default": "query.variant!=0"
						},
						{
							"cleanup_phase_2": "query.state_time>=0.5"
						}
					],
					"on_entry": [
						"/effect @s[tag=alien] clear",
						"/ability @s[m=c] mayfly true",
						"/ability @s[m=s] mayfly false",
						"/ability @s[m=a] mayfly false",
						"/clear @s omni:omni_icon",
						"/clear @s omni:omni_off",
