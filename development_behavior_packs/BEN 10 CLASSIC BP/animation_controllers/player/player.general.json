		"controller.animation.player_on_death": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"on_death": "query.health<=0"
						}
					]
				},
				"on_death": {
					"on_entry": [],
					"transitions": [
						{
							"default": "query.health>0"
						}
					]
				}
			}
		},
		"controller.animation.stopped_riding": {
			"states": {
				"default": {
					"transitions": [
						{
							"ride": "!query.is_riding"
						}
					]
				},
				"ride": {
					"on_entry": [
						"/execute as @s[family=waybig] at @s run function omni/off"
					],
					"transitions": [
						{
							"default": "query.is_riding"
						}
					]
				}
			}
		},
		"controller.animation.sneaked": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"sneaked": "query.is_sneaking"
						}
					]
				},
				"sneaked": {
					"on_entry": [
						"/event entity @s[family=ghostfreak,family=!invisible] ghostfreak_invisible",
						"/execute as @s[family=ghostfreak] at @s run effect @e[family=monster,r=15] blindness 1 1 true",
						"/effect @s[family=ghostfreak] invisibility 1 0 true"
					],
					"transitions": [
						{
							"default": "!query.is_sneaking"
						},
						{
							"loop_reset": "query.state_time>=0.2"
						}
					]
				},
				"loop_reset": {
					"transitions": [
						{
							"default": "!query.is_sneaking"
						},
						{
							"sneaked": "query.state_time>=0"
						}
					]
				}
			}
		},
		"controller.animation.on_air": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"on_air": "!query.is_on_ground"
						}
					]
				},
				"on_air": {
					"transitions": [
						{
							"default": "query.is_on_ground"
						}
					]
				}
			}
		},
		"controller.animation.on_ground": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"on_ground": "query.is_on_ground&&!query.is_in_water"
						}
					]
				},
				"on_ground": {
					"transitions": [
						{
							"default": "!query.is_on_ground||query.is_in_water"
						}
					],
					"on_entry": [
						"/tag @s remove flying",
						"/event entity @s[family=water_ripjaws] ripjaws"
					]
				}
			}
		},
		"controller.animation.in_water": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"in_water": "query.is_in_water"
						}
					]
				},
				"in_water": {
					"transitions": [
						{
							"default": "!query.is_in_water"
						}
					],
					"on_entry": [
						"/event entity @s[family=ripjaws,family=!water_ripjaws] water_ripjaws"
					]
				}
			}
		},
		"controller.animation.climb": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"climb": "query.is_jumping&&query.variant==6"
						}
					]
				},
				"climb": {
					"transitions": [
						{
							"default": "query.is_jumping&&query.variant==6"
						}
					],
					"on_entry": [
						"/execute as @s at @s if block ~ ~1 ~-1 air run tag @s add s1",
						"/execute as @s at @s if block ~1 ~1 ~0 air run tag @s add s2",
						"/execute as @s at @s if block ~ ~1 ~1 air run tag @s add s3",
						"/execute as @s at @s if block ~-1 ~1 ~0 air run tag @s add s4",
						"/tag @s[tag=s1,tag=s2,tag=s3,tag=s4] add cant_climb",
						"/tag @s remove s1",
						"/tag @s remove s2",
						"/tag @s remove s3",
						"/tag @s remove s4",
						"/effect @s[tag=!cant_climb] levitation 1 2 true",
						"/tag @s remove cant_climb"
					]
				}
			}
		},
		"controller.animation.jump": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"jump": "query.is_jumping"
						}
					]
				},
				"jump": {
					"transitions": [
						{
							"default": "!query.is_jumping"
						}
					],
					"on_entry": [
						"/effect @s[family=heatblast] levitation 1 5 true",
						"/effect @s[family=ghostfreak] levitation 1 5 true",
						"/effect @s[family=stinkfly] levitation 1 5 true",
						"/effect @s[family=stinkfly] speed 8 10 true",
						"/tag @s[family=can_fly] add flying"
					]
				}
			}
		},
		"controller.animation.sprint": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"sprint": "query.is_sprinting"
						}
					]
				},
				"sprint": {
					"transitions": [
						{
							"default": "!query.is_sprinting"
						},
						{
							"loop_reset": "query.state_time>=0.05"
						}
					],
					"on_entry": [
						"/effect @s[family=xlr8] speed 1 22 true",
						"/effect @s[family=cannonbolt_ball] speed 1 7 true",
						"/effect @s[family=stinkfly] speed 1 5 true",
						"/effect @s[family=cannonbolt_ball] jump_boost 1 5 true",
						"/execute as @s[family=xlr8] at @s run particle minecraft:soul_particle ~ ~0.2 ~",
						"/execute as @s[family=xlr8] at @s run particle minecraft:basic_smoke_particle ~ ~0.2 ~"
					]
				},
				"loop_reset": {
					"transitions": [
						{
							"default": "!query.is_sprinting"
						},
						{
							"sprint": "query.state_time>=0"
						}
					]
				}
			}
		},
		"controller.animation.no_sprint": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"no_sprint": "!query.is_sprinting"
						}
					]
				},
				"no_sprint": {
					"transitions": [
						{
							"default": "!query.is_sprinting"
						}
					],
					"on_entry": [
						"/event entity @s[family=xlr8_sprint] xlr8",
						"/event entity @s[family=cannonbolt_ball] cannonbolt"
					]
				}
			}
		},
		"controller.animation.sneak": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"sneak": "query.is_sneaking"
						}
					]
				},
				"sneak": {
					"transitions": [
						{
							"default": "!query.is_sneaking"
						}
					],
					"on_entry": [
						"/tag @s add sneaking",
						"/effect @s[tag=flying] slow_falling 1 0 true"
					]
				}
			}
		},
