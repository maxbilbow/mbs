						"/clear @s power:hb_flamethrower",
						"/clear @s power:dh_crystal",
						"/clear @s power:dh_spikes",
						"/clear @s power:sf_slime",
						"/clear @s power:dt_clone",
						"/clear @s power:dt_command",
						"/clear @s power:wb_stomp",
