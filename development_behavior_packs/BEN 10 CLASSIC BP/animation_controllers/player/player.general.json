				},
				"cleanup_phase_2": {
					"transitions": [
						{
							"default": "query.variant!=0"
						}
					],
					"on_entry": [
						"/effect @s[tag=alien] clear",
						"/ability @s[m=c] mayfly true",
						"/ability @s[m=s] mayfly false",
						"/ability @s[m=a] mayfly false",
