{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.wear_omnitrix": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"wear_omnitrix": "query.get_equipped_item_name('main_hand')=='omnitrix'&&(query.is_using_item||variable.attack_time>0.6)"
						}
					]
				},
				"wear_omnitrix": {
					"transitions": [
						{
							"default": "!(query.get_equipped_item_name('main_hand')=='omnitrix'&&(query.is_using_item||variable.attack_time>0.6))"
						}
					],
					"on_entry": [
						"/function wear/omnitrix",
						"/execute as @s[tag=!master_control] at @s run scriptevent omni:equip_power 0 omni:omni_icon",
						"/execute as @s[tag=master_control] at @s run scriptevent omni:equip_power 8 omni:omni_master"
					]
				}
			}
		},
		"controller.animation.omni_inuse": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"omni_inuse": "(query.get_equipped_item_name('main_hand')=='omni_icon'||query.get_equipped_item_name('main_hand')=='omni_master')&&query.skin_id>0"
						}
					]
				},
				"omni_inuse": {
					"transitions": [
						{
							"default": "(query.get_equipped_item_name('main_hand')=='omni_icon'||query.get_equipped_item_name('main_hand')=='omni_master')&&query.skin_id>0"
						}
					],
					"on_entry": [
						"/execute as @s[family=omni_inuse] at @s run function omni/display_alien_name"
					]
				}
			}
		},
		"controller.animation.omni_menu": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"omni_menu": "query.get_equipped_item_name('main_hand')=='omni_icon'&&query.is_sneaking&&query.skin_id==1"
						}
					]
				},
				"omni_menu": {
					"transitions": [
						{
							"default": "1"
						}
					],
					"on_entry": [
						"/tag @s add omni_menu",
						"/scoreboard objectives add omni_menu_option dummy",
						"/scoreboard players add @s omni_menu_option 0"
					]
				}
			}
		},
		"controller.animation.omni_menu_click": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"click": "query.get_equipped_item_name('main_hand')=='omni_icon'&&query.is_sneaking&&query.is_using_item&&query.skin_id==1"
						}
					]
				},
				"click": {
					"transitions": [
						{
							"default": "!query.is_using_item"
						},
						{
							"auto_scroll": "query.state_time>=0.3"
						}
					],
					"on_entry": [
						"/scoreboard players add @s omni_menu_option 1",
						"/scoreboard players set @s[scores={omni_menu_option=12..}] omni_menu_option 0",
						"/playsound omni.opt_change @s ~ ~ ~ 1.0 1.5"
					]
				},
				"auto_scroll": {
					"transitions": [
						{
							"default": "!query.is_using_item"
						},
						{
							"click": "query.state_time>=0.15"
						}
					]
				}
			}
		},
		"controller.animation.omni_menu_click_reverse": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"click": "query.get_equipped_item_name('main_hand')=='omni_icon'&&query.is_sneaking&&variable.attack_time>0&&query.skin_id==1"
						}
					]
				},
				"click": {
					"transitions": [
						{
							"default": "variable.attack_time==0"
						},
						{
							"auto_scroll": "query.state_time>=0.3"
						}
					],
					"on_entry": [
						"/scoreboard players remove @s omni_menu_option 1",
						"/scoreboard players set @s[scores={omni_menu_option=..-1}] omni_menu_option 11",
						"/playsound omni.opt_change @s ~ ~ ~ 1.0 1.5"
					]
				},
				"auto_scroll": {
					"transitions": [
						{
							"default": "variable.attack_time==0"
						},
						{
							"click": "query.state_time>=0.15"
						}
					]
				}
			}
		},
		"controller.animation.omni_icon_change": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"omni_icon_change": "(query.get_equipped_item_name('main_hand')=='omni_icon'||query.get_equipped_item_name('main_hand')=='omni_master')&&query.is_using_item&&(!query.is_sneaking||query.skin_id>1)"
						}
					]
				},
				"omni_icon_change": {
					"transitions": [
						{
							"wait_release": "query.state_time>=0.25"
						}
					],
					"on_entry": [
						"/playsound omni.opt_change @s[family=omnitrix,family=!alien]",
						"/event entity @s[family=omni_waybig] omnitrix",
						"/event entity @s[scores={aliens=..21},family=omni_clockwork] omnitrix",
						"/event entity @s[scores={aliens=22..},family=omni_clockwork] omni_waybig",
						"/event entity @s[scores={aliens=..20},family=omni_arctiguana] omnitrix",
						"/event entity @s[scores={aliens=21..},family=omni_arctiguana] omni_clockwork",
						"/event entity @s[scores={aliens=..19},family=omni_eyeguy] omnitrix",
						"/event entity @s[scores={aliens=20..},family=omni_eyeguy] omni_arctiguana",
						"/event entity @s[scores={aliens=..18},family=omni_ditto] omnitrix",
						"/event entity @s[scores={aliens=19..},family=omni_ditto] omni_eyeguy",
						"/event entity @s[scores={aliens=..17},family=omni_upchuck] omnitrix",
						"/event entity @s[scores={aliens=18..},family=omni_upchuck] omni_ditto",
						"/event entity @s[scores={aliens=..16},family=omni_benvictor] omnitrix",
						"/event entity @s[scores={aliens=17..},family=omni_benvictor] omni_upchuck",
						"/event entity @s[scores={aliens=..15},family=omni_benmummy] omnitrix",
						"/event entity @s[scores={aliens=16..},family=omni_benmummy] omni_benvictor",
						"/event entity @s[scores={aliens=..14},family=omni_benwolf] omnitrix",
						"/event entity @s[scores={aliens=15..},family=omni_benwolf] omni_benmummy",
						"/event entity @s[scores={aliens=..13},family=omni_wildvine] omnitrix",
						"/event entity @s[scores={aliens=14..},family=omni_wildvine] omni_benwolf",
						"/event entity @s[scores={aliens=..12},family=omni_cannonbolt] omnitrix",
						"/event entity @s[scores={aliens=13..},family=omni_cannonbolt] omni_wildvine",
						"/event entity @s[scores={aliens=..11},family=omni_upgrade] omnitrix",
						"/event entity @s[scores={aliens=12..},family=omni_upgrade] omni_cannonbolt",
						"/event entity @s[scores={aliens=..10},family=omni_ghostfreak] omnitrix",
						"/event entity @s[scores={aliens=11..},family=omni_ghostfreak] omni_upgrade",
						"/event entity @s[scores={aliens=..9},family=omni_ripjaws] omnitrix",
						"/event entity @s[scores={aliens=10..},family=omni_ripjaws] omni_ghostfreak",
						"/event entity @s[scores={aliens=..8},family=omni_stinkfly] omnitrix",
						"/event entity @s[scores={aliens=9..},family=omni_stinkfly] omni_ripjaws",
						"/event entity @s[scores={aliens=..7},family=omni_fourarms] omnitrix",
						"/event entity @s[scores={aliens=8..},family=omni_fourarms] omni_stinkfly",
						"/event entity @s[scores={aliens=..6},family=omni_greymatter] omnitrix",
						"/event entity @s[scores={aliens=7..},family=omni_greymatter] omni_fourarms",
						"/event entity @s[scores={aliens=..5},family=omni_xlr8] omnitrix",
						"/event entity @s[scores={aliens=6..},family=omni_xlr8] omni_greymatter",
						"/event entity @s[scores={aliens=..4},family=omni_diamondhead] omnitrix",
						"/event entity @s[scores={aliens=5..},family=omni_diamondhead] omni_xlr8",
						"/event entity @s[scores={aliens=..3},family=omni_wildmutt] omnitrix",
						"/event entity @s[scores={aliens=4..},family=omni_wildmutt] omni_diamondhead",
						"/event entity @s[scores={aliens=..2},family=omni_heatblast] omnitrix",
						"/event entity @s[scores={aliens=3..},family=omni_heatblast] omni_wildmutt",
						"/event entity @s[scores={aliens=..1},family=omni_unused] omnitrix",
						"/event entity @s[scores={aliens=2..},family=omni_unused] omni_heatblast",
						"/title @s[tag=aliens_locked,family=omni_unused] actionbar §r§cAliens are locked"
					]
				},
				"wait_release": {
					"transitions": [
						{
							"default": "!query.is_using_item"
						}
					]
				}
			}
		},
