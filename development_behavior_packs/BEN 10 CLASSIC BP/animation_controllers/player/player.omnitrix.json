		"controller.animation.omni_using": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"omni_using": "query.skin_id==5"
						}
					]
				},
				"omni_using": {
					"transitions": [
						{
							"default": "query.skin_id!=5"
						}
					],
					"on_entry": [
						"/playsound omni.used @s[tag=!omni_using]",
						"/tag @s add omni_using"
					]
				}
			}
		},
		"controller.animation.player_transform": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"player_transform": "query.skin_id==6"
						}
					]
				},
				"player_transform": {
					"transitions": [
						{
							"default": "query.skin_id==6"
						}
					],
					"on_entry": [
						"/tag @s remove omni_using",
						"/clear @s omni:omni_icon",
						"/clear @s omni:omni_master",
						"/particle minecraft:totem_particle ~ ~1 ~",
						"/particle minecraft:totem_particle ~ ~1 ~",
						"/event entity @s[family=omni_benvictor,tag=!master_control] benvictor",
						"/event entity @s[family=omni_clockwork,tag=!master_control] clockwork",
						"/event entity @s[family=omni_upchuck,tag=!master_control] upchuck",
						"/event entity @s[family=omni_arctiguana,tag=!master_control] arctiguana",
						"/event entity @s[family=omni_wildvine,tag=!master_control] wildvine",
						"/event entity @s[family=omni_benwolf,tag=!master_control] benwolf",
						"/event entity @s[family=omni_benmummy,tag=!master_control] benmummy",
						"/event entity @s[family=omni_eyeguy,tag=!master_control] eyeguy",
						"/event entity @s[family=omni_waybig,tag=!master_control] waybig",
						"/event entity @s[family=omni_ditto,tag=!master_control] ditto",
						"/event entity @s[family=omni_cannonbolt,tag=!master_control] cannonbolt",
						"/event entity @s[family=omni_ghostfreak,tag=!master_control] ghostfreak",
						"/event entity @s[family=omni_upgrade,tag=!master_control] upgrade",
						"/event entity @s[family=omni_ripjaws,tag=!master_control] ripjaws",
						"/event entity @s[family=omni_stinkfly,tag=!master_control] stinkfly",
						"/event entity @s[family=omni_fourarms,tag=!master_control] fourarms",
						"/event entity @s[family=omni_greymatter,tag=!master_control] greymatter",
						"/event entity @s[family=omni_xlr8,tag=!master_control] xlr8",
						"/event entity @s[family=omni_diamondhead,tag=!master_control] diamondhead",
						"/event entity @s[family=omni_wildmutt,tag=!master_control] wildmutt",
						"/event entity @s[family=omni_heatblast,tag=!master_control] heatblast",
						"/execute as @s[tag=master_control] at @s run function omni/random_transform",
						"/scoreboard objectives add ripjaws dummy",
						"/scoreboard objectives add omni_off dummy",
						"/scoreboard players add @s omni_off 0",
						"/scoreboard objectives add omni_charge dummy"
					]
				}
			}
		},
		"controller.animation.omnitrix_active_beep": {
			"initial_state": "default",
			"states": {
				"default": {
					"on_entry": [
						"/stopsound @a omni.idle"
					],
					"transitions": [
						{
							"beep": "(query.get_equipped_item_name('main_hand')=='omni_icon'||query.get_equipped_item_name('main_hand')=='omni_master')&&query.skin_id>2&&query.skin_id!=5&&query.skin_id!=6&&query.skin_id<50"
						}
					]
				},
				"beep": {
					"transitions": [
						{
							"default": "!(query.get_equipped_item_name('main_hand')=='omni_icon'||query.get_equipped_item_name('main_hand')=='omni_master')||query.skin_id<=2||query.skin_id==5||query.skin_id==6||query.skin_id>=50"
						},
						{
							"wait": "query.state_time>=0"
						}
					],
					"on_entry": [
						"/playsound omni.idle @a[r=8] ~ ~ ~ 0.3 1.0"
					]
				},
				"wait": {
					"transitions": [
						{
							"default": "!(query.get_equipped_item_name('main_hand')=='omni_icon'||query.get_equipped_item_name('main_hand')=='omni_master')||query.skin_id<=2||query.skin_id==5||query.skin_id==6||query.skin_id>=50"
						},
						{
							"beep": "query.state_time>=1.5"
						}
					]
				}
			}
		},
		"controller.animation.omni_off": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"omni_off": "query.get_equipped_item_name('main_hand')=='omni_off'&&query.is_using_item"
						}
					]
				},
				"omni_off": {
					"transitions": [
						{
							"default": "!query.is_using_item"
						}
					],
					"on_entry": [
						"/tag @s remove master_control",
						"/function omni/off"
					]
				}
			}
		}
	}
}