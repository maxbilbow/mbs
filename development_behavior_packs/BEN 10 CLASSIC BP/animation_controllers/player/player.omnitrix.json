						"/event entity @s[scores={aliens=18},family=omni_unused] omni_ditto",
						"/event entity @s[scores={aliens=17},family=omni_unused] omni_upchuck",
						"/event entity @s[scores={aliens=16},family=omni_unused] omni_benvictor",
						"/event entity @s[scores={aliens=15},family=omni_unused] omni_benmummy",
						"/event entity @s[scores={aliens=14},family=omni_unused] omni_benwolf",
						"/event entity @s[scores={aliens=13},family=omni_unused] omni_wildvine",
						"/event entity @s[scores={aliens=12},family=omni_unused] omni_cannonbolt",
