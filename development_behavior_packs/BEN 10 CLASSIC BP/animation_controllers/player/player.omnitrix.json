						}
					]
				},
				"omni_icon_change_reverse": {
					"transitions": [
						{
							"wait_release": "query.state_time>=0.25"
						}
					],
					"on_entry": [
						"/playsound omni.opt_change @s[family=omnitrix,family=!alien]",
						"/event entity @s[family=omni_heatblast] omnitrix",
						"/event entity @s[family=omni_wildmutt] omni_heatblast",
