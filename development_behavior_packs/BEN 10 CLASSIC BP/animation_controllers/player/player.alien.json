{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.player_alien": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"player_alien": "query.variant>0"
						}
					]
				},
				"player_alien": {
					"transitions": [
						{
							"default": "query.variant==0"
						}
					],
					"on_entry": [
						"/tag @s[family=alien] add alien",
						"/execute as @s[family=alien] at @s run scriptevent omni:equip_power 0 omni:omni_off",
						"/execute as @s[family=alien,tag=master_control] at @s run scriptevent omni:equip_power 8 omni:omni_master",
						"/ability @s[family=stinkfly] mayfly true",
						"/ability @s[family=heatblast] mayfly true",
						"/ability @s[family=ghostfreak] mayfly true"
					],
					"on_exit": [
						"/effect @s clear",
						"/ability @s[m=s] mayfly false",
						"/ability @s[m=a] mayfly false",
						"/tag @s remove alien"
					]
				}
			}
		},
		"controller.animation.waybig_ray": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"waybig_ray": "query.variant==15&&query.get_equipped_item_name('main_hand')=='wb_ray'&&query.is_using_item"
						}
					]
				},
				"waybig_ray": {
					"transitions": [
						{
							"default": "!query.is_using_item"
						}
					],
					"on_entry": [
						"/playanimation @e[c=1,type=player:waybig] shooting"
					]
				}
			}
		},
		"controller.animation.waybig_stomp": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"waybig_stomp": "query.variant==15&&query.get_equipped_item_name('main_hand')=='wb_stomp'&&query.is_using_item"
						}
					]
				},
				"waybig_stomp": {
					"transitions": [
						{
							"default": "!query.is_using_item"
						}
					],
					"on_entry": [
						"/event entity @e[c=1,type=player:waybig_height] wb_stomp"
					]
				}
			}
		},
		"controller.animation.waybig": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"waybig": "query.variant==15"
						}
					]
				},
				"waybig": {
					"transitions": [
						{
							"default": "query.variant!=15"
						}
					],
					"on_entry": [
						"/execute as @s run scriptevent omni:equip_power 1 power:wb_stomp",
						"/execute as @s run scriptevent omni:equip_power 2 power:wb_ray"
					]
				}
			}
		},
		"controller.animation.ditto": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"ditto": "query.variant==18"
						}
					]
				},
				"ditto": {
					"transitions": [
						{
							"default": "query.variant!=18"
						}
					],
					"on_entry": [
						"/scriptevent omni:equip_power 1 power:dt_clone",
						"/scriptevent omni:equip_power 2 power:dt_command",
						"/tag @s add ditto_owner"
					]
				}
			}
		},
		"controller.animation.ditto_clone": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"ditto_clone": "!query.is_sneaking&&query.variant==18&&query.get_equipped_item_name('main_hand')=='dt_clone'&&query.is_using_item"
						}
					]
				},
				"ditto_clone": {
					"transitions": [
						{
							"default": "!query.is_using_item||query.is_sneaking||query.get_equipped_item_name('main_hand')!='dt_clone'"
						}
					],
					"on_entry": [
						"/summon omni:ditto_clone ~~~"
					]
				}
			}
		},
		"controller.animation.ditto_clear_clone": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"ditto_clear_clone": "query.is_sneaking&&query.variant==18&&query.get_equipped_item_name('main_hand')=='dt_clone'&&query.is_using_item"
						}
					]
				},
				"ditto_clear_clone": {
					"transitions": [
						{
							"default": "!query.is_using_item||!query.is_sneaking||query.get_equipped_item_name('main_hand')!='dt_clone'"
						}
					],
					"on_entry": [
						"/event entity @e[c=1,type=omni:ditto_clone] despawn"
					]
				}
			}
		},
		"controller.animation.cannonbolt": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"cannonbolt": "query.variant==5"
						}
					]
				},
				"cannonbolt": {
					"transitions": [
						{
							"default": "query.variant!=5"
						}
					],
					"on_entry": [
						"/effect @s resistance 99999 1 true",
						"/effect @s slowness 99999 0 true"
					]
				}
			}
		},
		"controller.animation.cannonbolt_sprint": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"cannonbolt_sprint": "query.variant==5&&query.is_sprinting"
						}
					]
				},
				"cannonbolt_sprint": {
					"transitions": [
						{
							"default": "!query.is_sprinting||query.variant!=5"
						},
						{
							"sprint_loop": "query.state_time>=0.25"
						}
					],
					"on_entry": [
						"/event entity @s cannonbolt_ball",
						"/camerashake add @a[r=15] 0.15 0.5 rotational",
						"/playsound random.explode @a[r=10] ~ ~ ~ 0.5 1.5"
					]
				},
				"sprint_loop": {
					"transitions": [
						{
							"default": "!query.is_sprinting||query.variant!=5"
						},
						{
							"cannonbolt_sprint": "query.state_time>=0.1"
						}
					]
				}
			}
		},
		"controller.animation.ghostfreak": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"visible": "query.variant==11"
						},
						{
							"invisible": "query.variant==12"
						}
					]
				},
				"visible": {
					"transitions": [
						{
							"default": "query.variant!=11&&query.variant!=12"
						},
						{
							"turn_invisible": "query.is_sneaking"
						}
					],
					"on_entry": [
						"/effect @s invisibility 0",
						"/effect @s speed 0",
						"/effect @s night_vision 99999 0 true",
						"/execute as @s[family=alien] at @s run scriptevent omni:equip_power 1 power:gf_intangibility",
						"/execute as @s[family=alien] at @s run scriptevent omni:equip_power 2 power:gf_possession"
					]
				},
				"turn_invisible": {
					"transitions": [
						{
							"default": "query.variant!=11&&query.variant!=12"
						},
						{
							"invisible": "!query.is_sneaking"
						}
					],
					"on_entry": [
						"/event entity @s ghostfreak_invisible"
					]
				},
				"invisible": {
					"transitions": [
						{
							"default": "query.variant!=11&&query.variant!=12"
						},
						{
							"turn_visible": "query.is_sneaking"
						}
					],
					"on_entry": [
						"/effect @s invisibility 99999 0 true",
						"/effect @s speed 99999 5 true"
					]
				},
				"turn_visible": {
					"transitions": [
						{
							"default": "query.variant!=11&&query.variant!=12"
						},
						{
							"visible": "!query.is_sneaking"
						}
					],
					"on_entry": [
						"/event entity @s ghostfreak"
					]
				}
			}
		},
		"controller.animation.gf_intangibility": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"turn_intangible": "query.get_equipped_item_name('main_hand')=='gf_intangibility'&&query.is_using_item"
						}
					]
				},
				"turn_intangible": {
					"animations": [
						"gf_timer"
					],
					"transitions": [
						{
							"turn_tangible": "query.state_time>=10||(query.variant!=11&&query.variant!=12)"
						}
					],
					"on_entry": [
						"/tag @s[m=c] add was_creative",
						"/tag @s[m=a] add was_adventure",
						"/gamemode spectator @s",
						"/playsound mob.ghast.scream @s ~ ~ ~ 0.5 0.5"
					]
				},
				"turn_tangible": {
					"transitions": [
						{
							"default": "!query.is_using_item"
						}
					],
					"on_entry": [
						"/gamemode creative @s[tag=was_creative]",
						"/gamemode adventure @s[tag=was_adventure]",
						"/gamemode survival @s[tag=!was_creative,tag=!was_adventure]",
						"/tag @s remove was_creative",
						"/tag @s remove was_adventure",
						"/playsound mob.ghast.moan @s ~ ~ ~ 0.5 0.5"
					]
				}
			}
		},
		"controller.animation.gf_possession": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"grab_mob": "query.get_equipped_item_name('main_hand')=='gf_possession'&&query.is_using_item"
						}
					]
				},
				"grab_mob": {
					"transitions": [
						{
							"tp_loop_1": "0.05"
						}
					],
					"on_entry": [
						"/tag @e[r=4,c=1,family=!player,type=!item] add possessed",
						"/effect @s invisibility 99999 0 true",
						"/playsound mob.evocation_illager.cast @s ~ ~ ~ 1.0 0.5"
					]
				},
				"tp_loop_1": {
					"transitions": [
						{
							"release_mob": "query.is_sneaking||query.get_equipped_item_name('main_hand')!='gf_possession'"
						},
						{
							"tp_loop_2": "0.05"
						}
					],
					"on_entry": [
						"/tp @e[tag=possessed,r=10] @s"
					]
				},
				"tp_loop_2": {
					"transitions": [
						{
							"release_mob": "query.is_sneaking||query.get_equipped_item_name('main_hand')!='gf_possession'"
						},
						{
							"tp_loop_1": "0.05"
						}
					],
					"on_entry": [
						"/tp @e[tag=possessed,r=10] @s"
					]
				},
				"release_mob": {
					"transitions": [
						{
							"default": "!query.is_sneaking"
						}
					],
					"on_entry": [
						"/tag @e[tag=possessed] remove possessed",
						"/effect @s invisibility 0",
						"/playsound mob.evocation_illager.prepare_summon @s ~ ~ ~ 1.0 0.5"
					]
				}
			}
		},
		"controller.animation.upgrade": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"upgrade": "query.variant==10"
						}
					]
				},
				"upgrade": {
					"transitions": [
						{
							"default": "query.variant!=10"
						}
					],
					"on_entry": [
						"/effect @s resistance 99999 1 true"
					]
				}
			}
		},
		"controller.animation.ripjaws": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"water_form": "(query.variant==9||query.variant==999)&&query.is_in_water"
						},
						{
							"land_form_rain": "(query.variant==9||query.variant==999)&&query.is_in_water_or_rain&&!query.is_in_water"
						},
						{
							"land_form": "(query.variant==9||query.variant==999)&&!query.is_in_water_or_rain"
						}
					]
				},
				"land_form": {
					"transitions": [
						{
							"default": "query.variant!=9&&query.variant!=999"
						},
						{
							"water_form": "query.is_in_water"
						},
						{
							"land_form_rain": "query.is_in_water_or_rain"
						},
						{
							"suffocate_warning": "query.state_time>=20"
						}
					],
					"on_entry": [
						"/event entity @s ripjaws",
						"/effect @s water_breathing 99999 0 true",
						"/effect @s night_vision 99999 0 true"
					]
				},
				"land_form_rain": {
					"transitions": [
						{
							"default": "query.variant!=9&&query.variant!=999"
						},
						{
							"water_form": "query.is_in_water"
						},
						{
							"land_form": "!query.is_in_water_or_rain"
						}
					],
					"on_entry": [
						"/event entity @s ripjaws",
						"/effect @s water_breathing 99999 0 true",
						"/effect @s night_vision 99999 0 true",
						"/tag @s add rj_raining"
					],
					"on_exit": [
						"/tag @s remove rj_raining"
					]
				},
				"suffocate_warning": {
					"transitions": [
						{
							"default": "query.variant!=9&&query.variant!=999"
						},
						{
							"water_form": "query.is_in_water"
						},
						{
							"land_form_rain": "query.is_in_water_or_rain"
						},
						{
							"suffocate_damage": "query.state_time>=5"
						}
					],
					"on_entry": [
						"/titleraw @s actionbar {\"rawtext\":[{\"text\":\"§c§l> WARNING: Need Water to Survive! <\"}]}",
						"/playsound random.fizz @s ~ ~ ~ 1 0.8"
					]
				},
				"suffocate_damage": {
					"transitions": [
						{
							"default": "query.variant!=9&&query.variant!=999"
						},
						{
							"water_form": "query.is_in_water"
						},
						{
							"land_form_rain": "query.is_in_water_or_rain"
						},
						{
							"suffocate_loop": "query.state_time>=1.5"
						}
					],
					"on_entry": [
						"/damage @s 2 drowning"
					]
				},
				"suffocate_loop": {
					"transitions": [
						{
							"default": "query.variant!=9&&query.variant!=999"
						},
						{
							"water_form": "query.is_in_water"
						},
						{
							"land_form_rain": "query.is_in_water_or_rain"
						},
						{
							"suffocate_damage": "query.state_time>=0"
						}
					]
				},
				"water_form": {
					"transitions": [
						{
							"default": "query.variant!=9&&query.variant!=999"
						},
						{
							"land_form_rain": "query.is_in_water_or_rain&&!query.is_in_water"
						},
						{
							"land_form": "!query.is_in_water_or_rain"
						},
						{
							"water_dash": "query.is_sprinting"
						}
					],
					"on_entry": [
						"/event entity @s water_ripjaws",
						"/effect @s water_breathing 99999 255 true",
						"/effect @s night_vision 99999 255 true",
						"/effect @s conduit_power 99999 255 true",
						"/tag @s add in_water_rj"
					],
					"on_exit": [
						"/effect @s conduit_power 0",
						"/tag @s remove in_water_rj"
					]
				},
				"water_dash": {
					"transitions": [
						{
							"default": "query.variant!=9&&query.variant!=999"
						},
						{
							"land_form": "!query.is_in_water"
						},
						{
							"water_form": "!query.is_sprinting"
						},
						{
							"water_sprint": "query.state_time>=0.8"
						}
					],
					"on_entry": [
						"/effect @s speed 99999 8 true",
						"/playsound random.splash @s ~ ~ ~ 1 1.5",
						"/particle minecraft:bubble_column_up_particle ~ ~1 ~"
					],
					"on_exit": [
						"/effect @s speed 0"
					]
				},
				"water_sprint": {
					"transitions": [
						{
							"default": "query.variant!=9&&query.variant!=999"
						},
						{
							"land_form": "!query.is_in_water"
						},
						{
							"water_form": "!query.is_sprinting"
						}
					],
					"on_entry": [
						"/effect @s conduit_power 99999 255 true",
						"/effect @s speed 99999 6 true",
						"/playsound conduit.ambient @s ~ ~ ~ 1 1.5"
					],
					"on_exit": [
						"/effect @s speed 0",
						"/effect @s conduit_power 0"
					]
				}
			}
		},
		"controller.animation.stinkfly": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"stinkfly": "query.variant==8"
						}
					]
				},
				"stinkfly": {
					"transitions": [
						{
							"default": "query.variant!=8"
						}
					],
