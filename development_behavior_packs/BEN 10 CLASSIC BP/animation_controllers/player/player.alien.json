		"controller.animation.diamondhead": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"diamondhead": "query.variant==3"
						}
					]
				},
				"diamondhead": {
					"transitions": [
						{
							"default": "query.variant!=3"
						}
					],
					"on_entry": [
						"/effect @s jump_boost 99999 1 true",
						"/effect @s resistance 99999 10 true",
						"/execute as @s[family=alien] at @s run scriptevent omni:equip_power 1 power:dh_crystal",
						"/execute as @s[family=alien] at @s run scriptevent omni:equip_power 2 power:dh_spikes"
					]
				}
			}
		},
		"controller.animation.wildmutt": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"wildmutt": "query.variant==2"
						}
					],
					"on_entry": [
						"/fog @s remove custom_wildmutt_fog"
					]
				},
				"wildmutt": {
					"transitions": [
						{
							"default": "query.variant!=2"
						}
					],
					"on_entry": [
						"/effect @s speed 99999 2 true",
						"/effect @s jump_boost 99999 3 true",
						"/effect @s haste 99999 255 true",
						"/fog @s push wm:vision_fog custom_wildmutt_fog"
					],
					"on_exit": [
						"/fog @s remove custom_wildmutt_fog"
					]
				}
			}
		},
		"controller.animation.heatblast": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"heatblast": "query.variant==1"
						}
					]
				},
				"heatblast": {
					"transitions": [
						{
							"default": "query.variant!=1"
						}
