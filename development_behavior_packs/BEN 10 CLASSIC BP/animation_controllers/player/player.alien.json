		"controller.animation.xlr8_sprint": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"xlr8_sprint": "query.variant==4&&query.is_sprinting"
						}
					]
				},
				"xlr8_sprint": {
					"transitions": [
						{
							"default": "!query.is_sprinting||query.variant!=4"
