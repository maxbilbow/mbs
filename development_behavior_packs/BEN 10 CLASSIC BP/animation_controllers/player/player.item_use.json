		"controller.animation.up_tongue": {
			"initial_state": "preshoot",
			"states": {
				"preshoot": {
					"transitions": [
						{
							"shoot": "query.variant==17&&query.get_equipped_item_name('main_hand')=='up_tongue'&&(query.is_using_item||variable.attack_time>0)"
						}
					]
				},
				"shooting": {
					"on_entry": [
						"variable.delaytime=query.life_time;"
					],
					"transitions": [
						{
							"preshoot": "query.variant!=17||query.get_equipped_item_name('main_hand')!='up_tongue'||(!query.is_using_item&&variable.attack_time<=0)"
						},
						{
							"shoot": "query.variant!=17||query.get_equipped_item_name('main_hand')!='up_tongue'||(!query.is_using_item&&variable.attack_time<=0)"
						}
					]
				},
				"shoot": {
					"on_entry": [
						"/function player/tongue",
						"/scriptevent power:up_devour"
					],
					"transitions": [
						{
							"shooting": "1"
						}
					],
					"on_exit": [
						"variable.bullet_fire=query.life_time;"
					]
				}
			}
		},
		"controller.animation.up_eat": {
			"initial_state": "base",
			"states": {
				"base": {
					"transitions": [
						{
							"eat_normal": "query.variant==17&&query.is_sneaking&&query.get_equipped_item_name('main_hand')!=''&&query.get_equipped_item_name('main_hand')!='tnt'&&query.get_equipped_item_name('main_hand')!='slime'&&query.get_equipped_item_name('main_hand')!='slime_ball'&&query.get_equipped_item_name('main_hand')!='up_tongue'&&query.get_equipped_item_name('main_hand')!='up_menu'&&query.get_equipped_item_name('main_hand')!='omni_off'"
						},
						{
							"eat_bomb": "query.variant==17&&query.is_sneaking&&query.get_equipped_item_name('main_hand')=='tnt'"
						},
						{
							"eat_slime": "query.variant==17&&query.is_sneaking&&(query.get_equipped_item_name('main_hand')=='slime'||query.get_equipped_item_name('main_hand')=='slime_ball')"
						},
						{
							"spit_normal": "query.variant==17&&!query.is_sneaking&&query.skin_id==98"
						},
						{
							"spit_bomb": "query.variant==17&&!query.is_sneaking&&query.skin_id==99"
						},
						{
							"spit_slime": "query.variant==17&&!query.is_sneaking&&query.skin_id==100"
						}
					]
				},
				"eat_normal": {
					"transitions": [
						{
							"base": "!query.is_sneaking"
						}
					],
					"on_entry": [
						"/replaceitem entity @s slot.weapon.mainhand 0 air 1 0",
						"/event entity @s upchuck_eat",
						"/playanimation @s animation.up_eat"
					]
				},
				"spit_normal": {
					"transitions": [
						{
							"base": "query.is_sneaking||query.skin_id!=98"
						}
					],
					"on_entry": [
						"/event entity @s spit_normal",
						"/playanimation @s animation.up_spit",
						"/scriptevent power:up_spit"
					]
				},
				"eat_bomb": {
					"transitions": [
						{
							"base": "!query.is_sneaking"
						}
					],
					"on_entry": [
						"/replaceitem entity @s slot.weapon.mainhand 0 air 1 0",
						"/event entity @s upchuck_eat2",
						"/playanimation @s animation.up_eat"
					]
				},
				"spit_bomb": {
					"transitions": [
						{
							"base": "query.is_sneaking||query.skin_id!=99"
						}
					],
					"on_entry": [
						"/event entity @s spit_bomb",
						"/playanimation @s animation.up_spit",
						"/scriptevent power:up_spit"
					]
				},
				"eat_slime": {
					"transitions": [
						{
							"base": "!query.is_sneaking"
						}
					],
					"on_entry": [
						"/replaceitem entity @s slot.weapon.mainhand 0 air 1 0",
						"/event entity @s upchuck_eat3",
						"/playanimation @s animation.up_eat"
					]
				},
				"spit_slime": {
					"transitions": [
						{
							"base": "query.is_sneaking||query.skin_id!=100"
						}
					],
					"on_entry": [
						"/event entity @s spit_slime",
						"/playanimation @s animation.up_spit",
						"/scriptevent power:up_spit"
					]
				}
			}
		},
