{
	"format_version": "1.20.0",
	"minecraft:entity": {
		"description": {
			"identifier": "power:fire_ball",
			"is_spawnable": false,
			"is_summonable": true,
			"is_experimental": false,
			"runtime_identifier": "minecraft:snowball",
			"scripts": {
				"animate": [
					"fire",
					"in_water"
				]
			},
			"animations": {
				"fire": "controller.animation.fire",
				"in_water": "controller.animation.in_water"
			}
		},
		"component_groups": {
			"despawn": {
				"minecraft:despawn": {}
			},
			"explode_group": {
				"minecraft:explode": {
					"fuse_length": 0,
					"fuse_lit": true,
					"power": 3,
					"causes_fire": true,
					"destroy_affected_by_griefing": true
				}
			}
		},
		"components": {
			"minecraft:type_family": {
				"family": [
					"fire"
				]
			},
			"minecraft:collision_box": {
				"width": 0.25,
				"height": 0.25
			},
			"minecraft:projectile": {
				"offset": [
					-0.5,
					-0.1,
					0
				],
				"on_hit": {
					"definition_event": {
						"affect_projectile": true,
						"event_trigger": {
							"event": "trigger_explosion",
							"target": "self"
						}
					}
				},
				"power": 1.5,
				"gravity": 0.03,
				"angleoffset": 0
			},
			"minecraft:physics": {}
		},
		"events": {
			"despawn": {
				"add": {
					"component_groups": [
						"despawn"
					]
				}
			},
			"trigger_explosion": {
				"add": {
					"component_groups": [
						"explode_group"
					]
				}
			}
		}
	}
}