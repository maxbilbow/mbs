				"queue_command": {
					"command": "scriptevent cso:play_music"
				},
				"set_property": {
					"cso:boss_music_playing": true
				}
			},
			"minecraft:on_stop_music": {
				"filters": {
					"all_of": [
						{
							"test": "bool_property",
							"operator": "==",
							"domain": "cso:boss_music_playing"
						},
						{
							"test": "enum_property",
							"domain": "cso:entity_state",
							"operator": "!=",
							"value": "death"
						}
					]
				},
				"queue_command": {
					"command": "scriptevent cso:stop_music"
				},
				"set_property": {
					"cso:boss_music_playing": false
				}
			}
		}
	}
}