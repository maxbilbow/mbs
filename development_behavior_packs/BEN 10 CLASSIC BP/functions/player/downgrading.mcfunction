execute as @s[family=irongolem] at @s run summon iron_golem ~ ~ ~
execute as @s[family=boat] at @s run summon boat ~ ~ ~
execute as @s[family=minecart] at @s run summon minecart ~ ~ ~
execute as @s[family=furnace] at @s run setblock ~ ~ ~ furnace
execute as @s[family=noteblock] at @s run setblock ~ ~ ~ noteblock
execute as @s[family=piston] at @s run setblock ~ ~ ~ piston
event entity @s[family=upgrade] upgrade