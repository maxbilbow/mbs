{
	"format_version": "1.20.80",
	"minecraft:entity": {
		"description": {
			"identifier": "kaboom:trinity_bomb_entity",
			"is_spawnable": false,
			"is_summonable": true,
			"is_experimental": false,
			"runtime_identifier": "minecraft:shulker"
		},
		"component_groups": {
			"kaboom:explode_nuke": {
				"minecraft:transformation": {
					"into": "kaboom:explode"
				}
			},
			"kaboom:timer": {
				"minecraft:timer": {
					"looping": true,
					"time": 1,
					"time_down_event": {
						"event": "kaboom:time_down"
					}
				}
			},
			"kaboom:age": {
				"minecraft:ageable": {
					"duration": 10,
					"grow_up": {
						"event": "kaboom:explode_transform"
					}
				}
			},
			"kaboom:instant_despawn": {
				"minecraft:instant_despawn": {}
			},
			"kaboom:time_down_instant_despawn": {
				"minecraft:timer": {
					"looping": false,
					"time": 0,
					"time_down_event": {
						"event": "kaboom:instant_despawn"
					}
				}
			}
		},
		"components": {
			"minecraft:collision_box": {
				"width": 0.98,
				"height": 0.98
			},
			"minecraft:type_family": {
				"family": [
					"inanimate"
				]
			},
			"minecraft:damage_sensor": {
				"triggers": {
					"on_damage": {
						"target": "self",
						"event": "kaboom:hit_destroy"
					},
					"deals_damage": false
				}
			},
			"minecraft:scale": {
				"value": 2
			},
			"minecraft:is_baby": {},
			"minecraft:interact": {
				"interactions": {
					"on_interact": {
						"event": "kaboom:activate_timer"
					},
					"interact_text": "Detonate"
				}
			},
			"minecraft:loot": {
				"table": "loot_tables/item_atomic_bomb.json"
			}
		},
		"events": {
			"kaboom:explode_transform": {
				"add": {
					"component_groups": [
						"kaboom:explode_nuke"
					]
				}
			},
			"kaboom:activate_timer": {
				"add": {
					"component_groups": [
						"kaboom:timer",
						"kaboom:age"
					]
				}
			},
			"kaboom:time_down": {
				"queue_command": {
					"command": [
						"playsound note.bit @a[r=50] ~ ~ ~ 100 1.5 80"
					]
				}
			},
			"kaboom:hit_destroy": {
				"queue_command": {
					"command": [
						"loot spawn ~ ~ ~ loot item_atomic_bomb"
					]
				},
				"add": {
					"component_groups": [
						"kaboom:time_down_instant_despawn"
					]
				}
			},
			"kaboom:instant_despawn": {
				"add": {
					"component_groups": [
						"kaboom:instant_despawn"
					]
				}
			}
		}
	}
}