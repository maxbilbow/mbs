{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.glorbo_fruttodillo.attack": {
			"initial_state": "default",
			"states": {
				"default": {
					"blend_transition": 0.2,
					"transitions": [
						{
							"attack": "variable.attack_time > 0.0"
						}
					]
				},
				"attack": {
					"blend_transition": 0.5,
					"transitions": [
						{
							"default": "variable.attack_time <= 0.0"
						}
					],
					"animations": [
						"attack"
					]
				}
			}
		},
		"controller.animation.glorbo_fruttodillo.general": {
			"initial_state": "default",
			"states": {
				"default": {
					"blend_transition": 0.2,
					"transitions": [
						{
							"moving": "query.ground_speed>=0.1"
						}
					],
					"animations": [
						"idle"
					]
				},
				"moving": {
					"blend_transition": 0.2,
					"transitions": [
						{
							"default": "query.ground_speed<0.1"
						}
					],
					"animations": [
						"walk"
					]
				}
			}
		}
	}
}