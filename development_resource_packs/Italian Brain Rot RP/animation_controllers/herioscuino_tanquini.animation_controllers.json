{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.herioscuino_tanquini.attack": {
			"initial_state": "default",
			"states": {
				"default": {
					"blend_transition": 0.2,
					"transitions": [
						{
							"attack": "variable.attack_time > 0.0"
						}
					]
				},
				"attack": {
					"blend_transition": 0.2,
					"on_entry": [
						"v.random=math.random_integer(1,3);"
					],
					"transitions": [
						{
							"default": "variable.attack_time <= 0.0"
						}
					],
					"animations": [
						{
							"attack": "!query.property('eu:is_chad')"
						},
						{
							"attack_chad": "query.property('eu:is_chad') && v.random==1"
						},
						{
							"attack_chad2": "query.property('eu:is_chad') && v.random==2"
						},
						{
							"attack_chad3": "query.property('eu:is_chad') && v.random==3"
						}
					]
				}
			}
		},
		"controller.animation.herioscuino_tanquini.general": {
			"initial_state": "default",
			"states": {
				"default": {
					"blend_transition": 0.2,
					"transitions": [
						{
							"moving": "query.ground_speed>=0.1"
						}
					],
					"animations": [
						{
							"idle": "!query.property('eu:is_chad')"
						},
						{
							"idle_chad": "query.property('eu:is_chad')"
						}
					]
				},
				"moving": {
					"blend_transition": 0.2,
					"transitions": [
						{
							"default": "query.ground_speed<0.1"
						}
					],
					"animations": [
						{
							"walk": "!query.property('eu:is_chad')"
						},
						{
							"walk_chad": "query.property('eu:is_chad')"
						}
					]
				}
			}
		}
	}
}