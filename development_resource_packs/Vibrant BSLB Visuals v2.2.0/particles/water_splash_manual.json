{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:water_splash_particle_manual",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/splash_entity"
      }
    },
    "components": {
      "minecraft:emitter_rate_manual": {
        "max_particles": 28
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },

      "minecraft:emitter_shape_sphere": {
        "offset": [0.0, 0.3, 0.0],
        "radius": 0.45,
        "surface_only": true,
        "direction": "outwards"
      },

      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "Math.Random(0.5, 1.0)"
      },

      "minecraft:particle_initial_speed": "Math.Random(0.5, 1.2)",

      "minecraft:particle_initial_spin": {
        "rotation": "Math.Random(-15, 15)"
      },

      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0.0, "-8.6 + variable.particle_random_1*1.8", 0.0],
        "linear_drag_coefficient": 5.0
      },

      "minecraft:particle_motion_collision": {
        "coefficient_of_restitution": 0.05,
        "collision_drag": 12.0,
        "collision_radius": 0.01
      },

      "minecraft:particle_appearance_billboard": {
        "size": ["0.12 + variable.particle_random_2 * 0.08", "0.16 + variable.particle_random_2 * 0.10"],
        "facing_camera_mode": "rotate_y",
        "uv": {
          "texture_width": 112,
          "texture_height": 16,
          "flipbook": {
            "base_UV": [0, 0],
            "size_UV": [16, 16],
            "step_UV": [16, 0],
            "frames_per_second": 8,
            "max_frame": 7
          }
        }
      },

      "minecraft:particle_appearance_tinting": {
        "color": ["0.85 + variable.particle_random_3 * 0.15", "0.90 + variable.particle_random_3 * 0.10", 1.0, "1.0 - 0.6 * Math.Pow(variable.particle_age / variable.particle_lifetime, 2.0)"]
      },

      "minecraft:particle_expire_if_not_in_blocks": [
        "minecraft:air"
      ],
      "minecraft:particle_appearance_lighting": {}
    }
  }
}
