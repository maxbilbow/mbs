{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:water_drip_particle",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/glowing"
      }
    },
    "events": {
      "splash": {
        "particle_effect": {
          "effect": "minecraft:rain_splash_particle",
          "type": "particle"
        }
      }
    },
    "components": {
      "minecraft:emitter_rate_manual": { "max_particles": 50 },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },
      "minecraft:emitter_shape_point": {
        "offset": [ 0.0, 0.1, 0.0 ]
      },
      "minecraft:particle_initialization": {
        "per_update_expression": "variable.stuck_time = 2.0;",
        "per_render_expression": "variable.stuck_time = 2.0;"
      },
      "minecraft:particle_initial_speed": 0.0,
      "minecraft:particle_lifetime_expression": { "max_lifetime": 5.0 },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [ 0.0, -19.6, 0.0 ],
        "linear_drag_coefficient": "variable.stuck_time = 2.0; return variable.particle_age < variable.stuck_time ? 277 : 0.01;"
      },
      "minecraft:particle_motion_collision": {
        "expire_on_contact": true,
        "collision_radius": 0.01,
        "events": [
          { "event": "splash", "min_speed": 0.5 },
          { "event": "splash", "min_speed": 0.5 },
          { "event": "splash", "min_speed": 0.5 }
        ]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "variable.particle_age < variable.stuck_time ? 0.10 : 0.09",
          "variable.particle_age < variable.stuck_time ? 0.20 : 0.09"
        ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 16, "texture_height": 16,
          "uv": [ 0, 0 ], "uv_size": [ 16, 16 ]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": [
          "variable.particle_age < variable.stuck_time ? 0.1 : 0.2",
          "variable.particle_age < variable.stuck_time ? 0.3 + (variable.particle_age / variable.stuck_time) * 0.25 : 0.55",
          1.0,
          "variable.particle_age < variable.stuck_time ? 0.5 + (variable.particle_age / variable.stuck_time) * 0.5 : 0.95"
        ]
      }
    }
  }
}
