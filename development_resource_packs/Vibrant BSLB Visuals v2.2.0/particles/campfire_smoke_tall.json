{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:campfire_tall_smoke_particle",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/particle/campfire_smoke"
      }
    },
    "components": {

      "minecraft:emitter_shape_custom": {
        "offset": [
          "math.random(-0.12, 0.12)",
          0.0,
          "math.random(-0.12, 0.12)"
        ],
        "direction": [ 0.0, 1.0, 0.0 ]
      },
      "minecraft:emitter_rate_manual": {
        "max_particles": 200
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },

      "minecraft:particle_initial_speed": "math.random(0.7, 1.3)",

      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "math.random(7.0, 10.0)"
      },

      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          "(v.particle_random_1 * 2.0 - 1.0) * 0.06",
          "0.30 + v.particle_random_2 * 0.12",
          "(v.particle_random_3 * 2.0 - 1.0) * 0.06"
        ],
        "linear_drag_coefficient": 0.35
      },

      "minecraft:particle_motion_collision": {
        "enabled": "v.particle_age > 1",
        "collision_radius": 0.25
      },

      "minecraft:particle_initialization": {
        "per_render_expression": "v.t = v.particle_age / v.particle_lifetime; v.fade = math.clamp(v.particle_age / 0.4, 0, 1) * math.pow(1.0 - v.t, 0.10); v.size = (0.65 + v.particle_random_2 * 0.40) * math.pow(1.0 - v.t, 0.05);"
      },

      "minecraft:particle_appearance_billboard": {
        "size": [ "v.size", "v.size" ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 1,
          "texture_height": 12,
          "uv": [ 0, "math.floor(v.particle_random_2 * 12)" ],
          "uv_size": [ 1, 1 ]
        }
      },

      "minecraft:particle_appearance_tinting": {
        "color": [
          "0.68 + v.particle_random_1 * 0.1",
          "0.65 + v.particle_random_1 * 0.08",
          "0.60 + v.particle_random_1 * 0.06",
          "v.fade * (0.45 + v.particle_random_3 * 0.2)"
        ]
      }

    }
  }
}
