{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.entity.generic_melee_attack": {
            "initial_state": "default",
            "states": {
                "default": {
                    "blend_transition": 0.2,
                    "transitions": [
                        {
                            "moving": "query.ground_speed>=0.1"
                        },
                        {
                            "attack": "variable.attack_time > 0.0"
                        }
                    ],
                    "animations": [
                        "idle"
                    ]
                },
                "moving": {
                    "blend_transition": 0.2,
                    "transitions": [
                        {
                            "default": "query.ground_speed<0.1"
                        },
                        {
                            "attack": "variable.attack_time > 0.0"
                        }
                    ],
                    "animations": [
                        "walk"
                    ]
                },
                "attack": {
                    "blend_transition": 0.2,
                    "transitions": [
                        {
                            "default": "query.all_animations_finished"
                        }
                    ],
                    "animations": [
                        "attack"
                    ]
                }
            }
        }
    }
}