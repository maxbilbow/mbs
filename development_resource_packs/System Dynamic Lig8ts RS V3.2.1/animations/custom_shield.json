					"position":[0, -2, 0]
				}
			}
		},
		"animation.custom_shield.thierd_person.block_offhand": {
			"loop": true,
			"bones": {
				"leftitem": {
					"position": [ 2, 2, 11],
					"rotation": [ 90, 0, -90]
				},
				"shield2":{
					"scale":[1.15, 1.15, 1.15],
					"position":[0, -2, 0]
				}
			}
		}
	}
