		"controller.animation.bm_stretch_fp": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"shoot": "query.variant==21&&query.get_equipped_item_name('main_hand')=='bm_stretch'&&variable.is_first_person&&query.is_using_item||variable.attack_time>0"
						}
					],
					"blend_transition": 0.2
				},
				"shoot": {
					"animations": [
						"bm_stretch_fp"
					],
					"transitions": [
						{
							"default": "query.variant!=21||query.get_equipped_item_name('main_hand')!='bm_stretch'||!variable.is_first_person||!query.is_using_item&&variable.attack_time<=0"
						}
					],
					"blend_transition": 0.2
				}
			}
