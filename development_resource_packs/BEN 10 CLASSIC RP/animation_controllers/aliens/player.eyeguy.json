		"controller.animation.eyeguy_walk": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"shoot": "variable.on_ground&&query.variant==23&&query.is_moving&&!query.is_sprinting&&!variable.is_first_person&&!(query.get_equipped_item_name('main_hand')=='eyelaser'||query.get_equipped_item_name('main_hand')=='eyefire'||query.get_equipped_item_name('main_hand')=='eyeice'&&query.is_using_item)"
						}
					],
					"blend_transition": 0.2
				},
				"shoot": {
					"animations": [
						"eyeguy_walk"
					],
					"transitions": [
						{
							"default": "!variable.on_ground||query.variant!=23||!query.is_moving||query.is_sprinting||variable.is_first_person||(query.get_equipped_item_name('main_hand')=='eyelaser'||query.get_equipped_item_name('main_hand')=='eyefire'||query.get_equipped_item_name('main_hand')=='eyeice'&&query.is_using_item)"
						}
