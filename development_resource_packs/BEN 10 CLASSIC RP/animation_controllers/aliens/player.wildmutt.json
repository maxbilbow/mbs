{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.wildmutt_attack_fp": {
			"states": {
				"default": {
					"transitions": [
						{
							"attack": "variable.attack_time>0&&query.variant==2"
						}
					],
					"blend_transition": 0.2
				},
				"attack": {
					"animations": [
						{
							"wildmutt_attacking_fp": "variable.is_first_person"
						}
					],
					"transitions": [
						{
							"default": "query.all_animations_finished"
						}
					],
					"blend_transition": 0.2
				}
			}
		},
		"controller.animation.wildmutt_attack": {
			"states": {
				"default": {
					"transitions": [
						{
							"attack": "variable.attack_time>0&&query.variant==2"
						}
					],
					"blend_transition": 0.2
				},
				"attack": {
					"animations": [
						{
							"wildmutt_attacking": "!variable.is_first_person"
						}
					],
					"transitions": [
						{
							"default": "query.all_animations_finished"
						}
					],
					"blend_transition": 0.2
				}
			}
		},
		"controller.animation.wildmutt_jump": {
			"states": {
				"default": {
					"transitions": [
						{
							"jump": "!query.is_on_ground"
						}
					],
					"blend_transition": 0.2
				},
				"jump": {
					"animations": [
						{
							"wildmutt_jumping": "!variable.is_first_person&&query.variant==2"
						}
					],
					"transitions": [
						{
							"default": "query.is_on_ground"
						}
					],
					"blend_transition": 0.2
				}
			}
		},
		"controller.animation.wildmutt_movement": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"swimming": "query.variant==2&&query.is_in_water&&query.is_sprinting"
						}
					]
				},
				"swimming": {
					"animations": [
						"wildmutt_swimming"
					],
					"transitions": [
						{
							"default": "query.variant!=2||!query.is_in_water||!query.is_sprinting"
						}
					],
					"blend_transition": 0.4
				}
			}
		}
	}
}