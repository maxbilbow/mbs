		"controller.animation.upgrade_attack_fp": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"shoot": "query.variant==10&&query.skin_id==0&&variable.is_first_person&&variable.attack_time>0"
						}
					],
					"blend_transition": 0
				},
				"shoot": {
					"animations": [
						"upgrade_attack_fp"
					],
					"transitions": [
						{
							"default": "query.variant!=10||query.skin_id!=0||!variable.is_first_person||variable.attack_time<=0"
						}
					],
					"blend_transition": 0
				}
			}
		},
