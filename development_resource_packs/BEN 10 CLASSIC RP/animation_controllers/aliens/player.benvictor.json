			"states": {
				"default": {
					"transitions": [
						{
							"shoot": "variable.on_ground&&query.variant==22&&query.is_moving&&!query.is_sprinting&&!variable.is_first_person&&!((query.get_equipped_item_name('main_hand')=='bv_lightning'||query.get_equipped_item_name('main_hand')=='bv_electrokinesis')&&query.is_using_item)"
						}
					],
					"blend_transition": 0.2
				},
				"shoot": {
					"animations": [
						"benvictor_walk"
					],
					"transitions": [
						{
							"default": "!variable.on_ground||query.variant!=22||!query.is_moving||query.is_sprinting||variable.is_first_person||((query.get_equipped_item_name('main_hand')=='bv_lightning'||query.get_equipped_item_name('main_hand')=='bv_electrokinesis')&&query.is_using_item)"
						}
					],
