						}
					],
					"blend_transition": 0.2
				}
			}
		},
		"controller.animation.benvictor_jump": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"shoot": "!variable.on_ground&&query.variant==22&&!variable.is_first_person"
						}
					],
					"blend_transition": 0.2
				},
				"shoot": {
					"animations": [
						"benvictor_jump"
					],
					"transitions": [
