{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.bv_lightning_fp": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"shoot": "query.variant==22&&query.get_equipped_item_name('main_hand')=='bv_lightning'&&variable.is_first_person&&query.is_using_item&&!query.is_sneaking"
						}
					],
					"blend_transition": 0
				},
				"shoot": {
					"animations": [
						"bv_lightning_fp"
					],
					"transitions": [
						{
							"default": "query.variant!=22||query.get_equipped_item_name('main_hand')!='bv_lightning'||!variable.is_first_person||!query.is_using_item||query.is_sneaking"
						}
					],
					"blend_transition": 0
				}
			}
		},
