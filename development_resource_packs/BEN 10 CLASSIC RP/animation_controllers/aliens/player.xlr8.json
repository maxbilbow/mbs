{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.xlr8_attack_fp": {
			"states": {
				"default": {
					"transitions": [
						{
							"attack": "variable.attack_time>0&&variable.xlr8"
						}
					],
					"blend_transition": 0.2
				},
				"attack": {
					"animations": [
						{
							"xlr8_attacking_fp": "variable.is_first_person"
						}
					],
					"transitions": [
						{
							"default": "query.all_animations_finished"
						}
					],
					"blend_transition": 0.2
				}
			}
		},
		"controller.animation.xlr8_attack": {
			"states": {
				"default": {
					"transitions": [
						{
							"attack": "variable.attack_time>0&&variable.xlr8"
						}
					],
					"blend_transition": 0.2
				},
				"attack": {
					"animations": [
						{
							"xlr8_attacking": "!variable.is_first_person"
						}
					],
					"transitions": [
						{
							"default": "query.all_animations_finished"
						}
					],
					"blend_transition": 0.2
				}
			}
		},
		"controller.animation.xlr8_sneak": {
			"states": {
				"default": {
					"transitions": [
						{
							"sneak": "query.is_sneaking"
						}
					],
					"blend_transition": 0.3
				},
				"sneak": {
					"animations": [
						{
							"xlr8_sneaking": "variable.on_ground&&!variable.is_first_person&&!query.is_moving&&variable.xlr8"
						}
					],
					"transitions": [
						{
							"default": "!query.is_sneaking"
						}
					],
					"blend_transition": 0.3
				}
			}
		},
		"controller.animation.xlr8_jump": {
			"states": {
				"default": {
					"transitions": [
						{
							"jump": "!query.is_on_ground"
						}
					],
					"blend_transition": 0.2
				},
				"jump": {
					"animations": [
						{
							"xlr8_jumping": "!variable.is_first_person&&variable.xlr8"
						}
					],
					"transitions": [
						{
							"default": "query.is_on_ground"
						}
					],
					"blend_transition": 0.2
				}
			}
		},
		"controller.animation.xlr8_movement": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"swimming": "variable.xlr8&&query.is_in_water&&query.is_sprinting"
						}
					]
				},
				"swimming": {
					"animations": [
						"xlr8_swimming"
					],
					"transitions": [
						{
							"default": "!variable.xlr8||!query.is_in_water||!query.is_sprinting"
						}
					],
					"blend_transition": 0.4
				}
			}
		}
	}
}